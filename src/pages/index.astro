---
import Layout from '../components/Layout.astro'
import ModuleGrid from '../components/ModuleGrid.astro'
import Pagination from '../components/Pagination.astro'
import AdSlot from '../components/AdSlot.astro'
import { getSiteData } from '../lib/modules'

const data = await getSiteData()
const modules = data.listItems.slice(0, data.pageSize)
const pageCount = Math.ceil(data.listItems.length / data.pageSize)
---

<Layout title="Xposed Module Repository">
  <section class="page-heading">
    <div>
      <h1>Xposed Module Repository</h1>
      <p>{data.listItems.length} modules, generated from GitHub releases.</p>
    </div>
    <a class="btn btn-primary" href="/submission/">Submit Module</a>
  </section>
  <AdSlot slot={import.meta.env.PUBLIC_AD_SLOT_TOP} />
  <ModuleGrid modules={modules} />
  <Pagination current={1} pageCount={pageCount} />
</Layout>
