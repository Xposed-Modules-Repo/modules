GRAPHQL_TOKEN=

# Optional build tuning
GITHUB_ORG=Xposed-Modules-Repo
# REPO=Xposed-Modules-Repo/com.example.module
# DIRTY_REPOS=
# DIRTY_REPOS_ENDPOINT=
# DIRTY_REPOS_TOKEN=
# MODULES_CACHE_DIR=node_modules/.astro/modules-cache
# GITHUB_DETAIL_BATCH_SIZE=10
# GITHUB_REQUEST_DELAY_MS=750
# USE_GITHUB_MARKDOWN_API=true
# CMARK_GFM_BIN=

# Optional persistent build cache in Cloudflare D1
# D1_CACHE_DATABASE_ID=
# D1_CACHE_ACCOUNT_ID=8911df62bfddad67b7d7e84ae666bc87
# D1_CACHE_API_TOKEN=
# D1_CACHE_ENDPOINT=https://modules-webhook-debouncer.lsposed.workers.dev
# D1_CACHE_PREFIX=modules-cache:v1
# D1_CACHE_TTL_SECONDS=2592000
# D1_CACHE_CLEANUP_INTERVAL_SECONDS=86400
# D1_CACHE_MAX_ENTRY_BYTES=1500000
# D1_CACHE_MAX_TOTAL_BYTES=367001600
# D1_CACHE_READS=true
# D1_CACHE_WRITES=true

# Optional signed asset proxy
# ASSET_PROXY_BASE=https://assets.lsposed.org
# ASSET_PROXY_KEY=
# ASSET_PROXY_TIMESTAMP=6a03bf00
# ASSET_PROXY_SIGNATURE_PARAM=sign
# ASSET_PROXY_TIMESTAMP_PARAM=t

# Optional local verification
# USE_SAMPLE_DATA=true

